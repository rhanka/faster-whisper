{
  "name": "faster-whisper-ts",
  "version": "0.1.0",
  "description": "TypeScript port of SYSTRAN/faster-whisper for Node.js, built on CTranslate2, Koffi, FFmpeg, and ONNX Runtime.",
  "type": "commonjs",
  "main": "./dist/src/index.js",
  "module": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "require": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    }
  },
  "files": [
    "dist/src",
    "assets",
    "scripts/build-native.js",
    "scripts/fetch-test-model.js",
    "whisper_bridge/CMakeLists.txt",
    "whisper_bridge/bridge.cpp",
    "whisper_bridge/bridge.h",
    "whisper_bridge/pocketfft_hdronly.h",
    "whisper_bridge/lib",
    "whisper_bridge/vendor/ctranslate2/include",
    "whisper_bridge/vendor/ctranslate2/LICENSE"
  ],
  "scripts": {
    "build:native": "node scripts/build-native.js",
    "build:ts": "tsc -p tsconfig.json",
    "build": "npm run build:native && npm run build:ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test:prepare-model": "node scripts/fetch-test-model.js",
    "test:bridge": "node dist/tests/test_bridge.js",
    "test:audio": "node dist/tests/test_audio.js",
    "test:tokenizer": "node dist/tests/test_tokenizer.js",
    "test:feature-extractor": "node dist/tests/test_feature_extractor.js",
    "test:vad": "node dist/tests/test_vad.js",
    "test:transcribe": "node dist/tests/test_transcribe.js",
    "test:smoke": "npm run test:bridge && npm run test:audio && npm run test:tokenizer && npm run test:feature-extractor && npm run test:vad && npm run test:transcribe",
    "test": "npm run build && npm run test:prepare-model && npm run test:smoke",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "npm run test",
    "postinstall": "npm run build:native"
  },
  "keywords": [
    "whisper",
    "transcription",
    "ctranslate2",
    "typescript",
    "nodejs",
    "speech-to-text"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rhanka/faster-whisper.git"
  },
  "homepage": "https://github.com/rhanka/faster-whisper",
  "bugs": {
    "url": "https://github.com/rhanka/faster-whisper/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "cmake-js": "^8.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@ffmpeg/core": "^0.11.0",
    "@ffmpeg/ffmpeg": "^0.11.6",
    "@ffmpeg/util": "^0.12.2",
    "@huggingface/tokenizers": "^0.1.3",
    "ffmpeg-static": "^5.3.0",
    "koffi": "^2.15.6",
    "onnxruntime-node": "^1.24.3"
  }
}
